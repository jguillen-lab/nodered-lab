    {
        "id": "d92200f14264ae57",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "min max red",
        "func": "const ent = env.get('LIGHT_ENTITY');\nconst attrs = msg?.data?.new_state?.attributes || {};\n\nconst minK = attrs.min_color_temp_kelvin;\nconst maxK = attrs.max_color_temp_kelvin;\n\nif (typeof minK === 'number' && typeof maxK === 'number') {\n    flow.set(`ctRange.${ent}`, {\n        min_mireds: Math.round(1000000 / maxK), // Para tus otros scripts viejos\n        max_mireds: Math.round(1000000 / minK),\n        min_kelvin: minK,\n        max_kelvin: maxK\n    });\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 170,
        "y": 420,
        "wires": [
            []
        ]
    },
    {
        "id": "012e6d5bc84cf863",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "min max red",
        "func": "const keys = flow.keys(); // todas las claves del store por defecto\nconst dump = {};\nfor (const k of keys) {\n    dump[k] = flow.get(k); // lee cada valor\n}\nmsg.payload = dump;\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
