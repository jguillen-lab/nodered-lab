    {
        "id": "fn_build_reminder",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "Preparar recordatorio (+msg.delay)",
        "func": "const rawId = (env.get('LIGHT_ENTITY') || env.get('FRIENDLY_NAME') || 'auto_ct').toString();\nmsg.notify_id = rawId.replace(/[^a-zA-Z0-9_]/g, '_');\n\n\nconst mins = Number(msg.timeout_state?.state) || 90;\nmsg.delay = mins * 60000; // ms para nodo delay\n\n// Construye textos\nconst name = env.get('FRIENDLY_NAME') || env.get('LIGHT_ENTITY');\nconst actionAuto = env.get('ACTION_AUTO') || '';\nconst actionKeep = env.get('ACTION_KEEP') || '';\n\nmsg.notify = {\n  title: `Temperatura manual en ${name}`,\n  message: `Has cambiado la temperatura de ${name}. ¿Volvemos a modo Auto?\\n\\n- Para volver a Auto: activa el interruptor ${env.get('AUTO_BOOLEAN')}.`,\n  data: {\n    tag: msg.notify_id,\n    actions: actionAuto && actionKeep ? [\n      { action: actionAuto, title: \"Volver a Auto\" },\n    ] : []\n  }\n};\n\nmsg.notify_json = JSON.stringify({\n  title: msg.notify.title,\n  message: msg.notify.message,\n  data: msg.notify.data\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1020,
        "y": 480,
        "wires": [
