        "id": "ad13b624b4a2593c",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "inject test",
        "func": "const name = env.get('FRIENDLY_NAME') || env.get('LIGHT_ENTITY') || 'Luz';\nconst rawId = (env.get('LIGHT_ENTITY') || env.get('FRIENDLY_NAME') || 'auto_ct') + '';\nmsg.notify_id = rawId.replace(/[^a-zA-Z0-9_]/g,'_');\n\nconst actionAuto = env.get('ACTION_AUTO') || 'AUTO_ON_CAJA_ESCALERA_CP';\nconst actionKeep = env.get('ACTION_KEEP') || 'KEEP_MANUAL_CAJA_ESCALERA_CP';\n\nmsg.notify = {\n  title: `Temperatura manual en ${name} (TEST)`,\n  message: `Esto es un test de notificación para ${name}.`,\n  data: {\n    tag: msg.notify_id,\n    actions: (actionAuto && actionKeep) ? [\n      { action: actionAuto, title: \"Volver a Auto\" },\n      { action: actionKeep, title: \"Seguir en manual\" }\n    ] : []\n  }\n};\n\n// Pre-serializa para el nodo notify\nmsg.notify_json = JSON.stringify({\n  title: msg.notify.title,\n  message: msg.notify.message,\n  data: msg.notify.data\n});\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1660,
        "y": 540,
        "wires": [
