    {
        "id": "3b59de955c718e6c",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "Solo si OFF→ON",
        "func": "// Soporta old/new en msg.data o msg.payload según versión del nodo HA\nconst get = (o, p, d = undefined) => p.split('.').reduce((a, k) => (a && a[k] !== undefined) ? a[k] : undefined, o) ?? d;\n\nconst os = get(msg, 'data.old_state') || get(msg, 'payload.old_state') || {};\nconst ns = get(msg, 'data.new_state') || get(msg, 'payload.new_state') || {};\n\n// Dejar pasar SOLO transición OFF -> ON\nif (os.state !== 'on' && ns.state === 'on') {\n    return msg;\n}\nreturn null; // Bloquea cambios de atributos con la luz ya encendida\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 190,
        "y": 340,
        "wires": [
            [
                "cs_auto_on2"
            ]
        ]
    },
