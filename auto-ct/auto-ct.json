    {
        "id": "fn_detect_manual",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "Detectar cambio MANUAL",
        "func": "// Ignora rebotes tras escritura automática (compartido por flow)\nconst suppressMs = 4000;\nconst lastWrite = flow.get('last_auto_write') || 0;\nif (Date.now() - lastWrite < suppressMs) return null;\n\n// Estructuras de estado (soporta msg.data y msg.payload según versión del nodo)\nconst get = (o, p, d = undefined) => p.split('.').reduce((a, k) => (a && a[k] !== undefined) ? a[k] : undefined, o) ?? d;\n\nconst os = get(msg, 'data.old_state') || get(msg, 'payload.old_state') || {};\nconst ns = get(msg, 'data.new_state') || get(msg, 'payload.new_state') || {};\n\nconst oldOn = os.state === 'on';\nconst newOn = ns.state === 'on';\n\n// 1) Ignorar encendido/apagado\nif (!oldOn || !newOn) return null;\n\n// CAMBIO AQUÍ: Ahora buscamos 'color_temp_kelvin'\nconst oldCT = os.attributes?.color_temp_kelvin;\nconst newCT = ns.attributes?.color_temp_kelvin;\n\nconst oldMode = os.attributes?.color_mode;\nconst newMode = ns.attributes?.color_mode;\n\nconst byUser = !!(ns.context && ns.context.user_id);\n\n// AJUSTE DE UMBRAL: \n// 20 mireds es un cambio pequeño, pero 20 Kelvin es imperceptible.\n// Para mantener una sensibilidad similar a la que tenías (20 mireds), \n// un umbral de 200 o 300 Kelvin es más realista.\nconst threshold = Number(env.get('MANUAL_THRESHOLD_KELVIN')) || 250;\n\nlet manual = false;\n\n// 2) Cambio de modo (CT <-> hs/rgb/xy) hecho por usuario\nif (byUser && oldMode && newMode && oldMode !== newMode) manual = true;\n\n// 3) Cambio significativo de CT (Kelvin)\nif (typeof oldCT === 'number' && typeof newCT === 'number') {\n  if (Math.abs(newCT - oldCT) >= threshold) manual = true;\n}\n\n// 4) Si falta CT en alguno\nif ((typeof oldCT !== 'number' || typeof newCT !== 'number') && !(byUser && oldMode && newMode && oldMode !== newMode)) {\n  manual = false;\n}\n\nif (manual) {\n  msg.payload = { reason: byUser ? 'byUser' : 'diff/mode', oldCT, newCT, oldMode, newMode };\n  return msg;\n}\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 220,
        "y": 540,
        "wires": [
            [
                "svc_auto_off"
            ]
        ]
    },
