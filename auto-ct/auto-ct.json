    {
        "id": "fn_calc_ct2",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "Calcular CT desde elevación",
        "func": "const minK = Number(env.get('MIN_K')) || 2200;\nconst maxK = Number(env.get('MAX_K')) || 6200;\nconst transition = Number(env.get('TRANSITION_SEC')) || 2;\n\n// 1) Curva ideal -> mireds\nconst elev = Number(msg.elev);\nlet k;\nif (isNaN(elev)) { k = (minK + maxK) / 2; }\nelse if (elev <= -6) { k = minK; }\nelse if (elev >= 60) { k = maxK; }\nelse { const n = (elev + 6) / (60 + 6); k = minK + n * (maxK - minK); }\nlet ct = Math.round(1000000 / k);\n\n// 2) CLAMP a capacidades de la bombilla (mismo bloque que en A)\nconst ent = env.get('LIGHT_ENTITY');\nconst evAttrs = msg?.data?.new_state?.attributes || {};\nlet minM = evAttrs.min_mireds;\nlet maxM = evAttrs.max_mireds;\n\nif ((typeof minM !== 'number' || typeof maxM !== 'number') &&\n    typeof evAttrs.min_color_temp_kelvin === 'number' &&\n    typeof evAttrs.max_color_temp_kelvin === 'number') {\n    minM = Math.round(1000000 / evAttrs.max_color_temp_kelvin);\n    maxM = Math.round(1000000 / evAttrs.min_color_temp_kelvin);\n}\nif (typeof minM !== 'number' || typeof maxM !== 'number') {\n    const r = flow.get(`ctRange.${ent}`);\n    if (r) { minM = r.min_mireds; maxM = r.max_mireds; }\n}\nif (typeof minM === 'number' && typeof maxM === 'number') {\n    ct = Math.max(minM, Math.min(maxM, ct));\n    flow.set(`ctRange.${ent}`, {\n        min_mireds: minM,\n        max_mireds: maxM,\n        min_kelvin: Math.round(1000000 / maxM),\n        max_kelvin: Math.round(1000000 / minM),\n    });\n}\n\n// 3) Guarda último CT y lanza comando\ncontext.set('last_ct', ct);\nmsg.data = { color_temp: ct, transition };\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 340,
        "wires": [
            [
                "svc_set_ct"
            ]
        ]
    },
