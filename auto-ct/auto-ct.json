    {
        "id": "fn_calc_ct",
        "type": "function",
        "z": "subflow_auto_ct",
        "name": "Calcular CT desde elevación",
        "func": "// Lee parámetros de la curva \"ideal\"\nconst minK = Number(env.get('MIN_K')) || 2200;\nconst maxK = Number(env.get('MAX_K')) || 6200;\nconst transition = Number(env.get('TRANSITION_SEC')) || 2;\nconst threshold = Number(env.get('CT_THRESHOLD')) || 10; // mireds\n\n// 1) Curva ideal -> mireds\nconst elev = Number(msg.elev);\nlet k;\nif (isNaN(elev)) {\n  k = (minK + maxK) / 2;\n} else if (elev <= -6) {\n  k = minK;\n} else if (elev >= 60) {\n  k = maxK;\n} else {\n  const n = (elev + 6) / (60 + 6); // -6..60 -> 0..1\n  k = minK + n * (maxK - minK);\n}\nlet ct = Math.round(k); // Trabajamos directamente en Kelvin\n\n// 2) CLAMP a las capacidades reales\nconst ent = env.get('LIGHT_ENTITY');\nconst evAttrs = msg?.data?.new_state?.attributes || {};\n\n// Ahora el estándar es Kelvin\nlet minK_bulb = evAttrs.min_color_temp_kelvin;\nlet maxK_bulb = evAttrs.max_color_temp_kelvin;\n\n// Fallback al flow si no vienen en el evento\nif (typeof minK_bulb !== 'number') {\n  const r = flow.get(`ctRange.${ent}`);\n  if (r) { minK_bulb = r.min_kelvin; maxK_bulb = r.max_kelvin; }\n}\n\nif (typeof minK_bulb === 'number') {\n  ct = Math.max(minK_bulb, Math.min(maxK_bulb, ct));\n}\n\n// 3) Umbral (threshold) - IMPORTANTE\n// Como ahora 'ct' es Kelvin, un threshold de 10 es muy poco.\n// Cambia la lógica del threshold a algo como 150 Kelvin para no spamear.\nconst prev = context.get('last_ct') || 0;\nif (Math.abs(ct - prev) < 150) return null;\ncontext.set('last_ct', ct);\n\nmsg.data = { color_temp_kelvin: ct, transition }; // Nombre de propiedad actualizado\nreturn msg;\n",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 160,
        "wires": [
            [
                "svc_set_ct"
            ]
        ]
    },
